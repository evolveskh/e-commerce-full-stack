[
  {
    "label": "Run HTTP Request",
    "command": "httpyac",
    "args": ["send", "--line", "$ZED_ROW", "$ZED_FILE", "--env", "default"],
    "tags": ["http-request"],
    "reveal": "always",
  },
  {
    "label": "Run All HTTP Requests",
    "command": "httpyac",
    "args": ["send", "$ZED_FILE", "--all", "--env", "default"],
    "tags": ["http-request"],
    "reveal": "always",
  },
]
